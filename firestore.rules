rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /clientes/{usuarioId} {
      allow read: if request.auth != null && request.auth.uid == usuarioId;
      allow write: if false;
    }
    match /recuperacionPrivada/{documento} {
      allow read, write: if false;
    }
    match /intentosRecuperacion/{documento} {
      allow read, write: if false;
    }
    match /pedidos/{pedidoId} {
      allow create: if request.auth != null
        && request.resource.data.clienteId == request.auth.uid;
      allow read: if request.auth != null
        && resource.data.clienteId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
