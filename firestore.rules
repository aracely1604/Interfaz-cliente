rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function esPersonal() {
      return request.auth != null
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol in ['admin', 'delivery'];
    }

    match /clientes/{usuarioId} {
      allow read: if request.auth != null && request.auth.uid == usuarioId;
      allow write: if false;
    }
    match /recuperacionPrivada/{documento} {
      allow read, write: if false;
    }
    match /intentosRecuperacion/{documento} {
      allow read, write: if false;
    }
    match /pedidos/{pedidoId} {
      allow create: if request.auth != null
        && request.resource.data.clienteId == request.auth.uid;
      allow read: if request.auth != null
        && (resource.data.clienteId == request.auth.uid || esPersonal());
      allow update: if esPersonal()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'estado',
          'actualizadoEn',
          'entregadoEn',
          'repartidorId',
          'repartidorNombre',
          'repartidorAuto'
        ]);
      allow delete: if false;
    }
  }
}
